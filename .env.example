# TrackFights — environment variables
#
# Both are OPTIONAL. When using the web UI you can paste your key directly
# (stored in your browser's localStorage only). Server-side env vars are a
# convenience for self-hosted deployments.
#
# Get a Claude key:  https://console.anthropic.com/settings/keys
# Get a Gemini key (free tier): https://aistudio.google.com/app/apikey

ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
